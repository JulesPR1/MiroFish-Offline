# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# This fork runs entirely on local models — no cloud APIs needed.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (OpenAI-compatible format) =====
# Points to LM Studio server running Qwen3.5-35B-A3B
LLM_API_KEY=LM_TOKEN
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL_NAME=qwen3.5-35b-a3b

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration =====
# Uses LM Studio's embedding endpoint (if available)
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://127.0.0.1:1234
# For Docker: EMBEDDING_BASE_URL=http://ollama:11434

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to same LM Studio server
OPENAI_API_KEY=LM_TOKEN
OPENAI_API_BASE_URL=http://127.0.0.1:1234

# ===== Docker-mode overrides =====
# Uncomment these when running the backend inside Docker.
# LM Studio runs on your HOST machine, not in Docker, so use host.docker.internal
# (works on Mac and Windows; on Linux add --add-host=host.docker.internal:host-gateway to docker run)
# LLM_BASE_URL=http://host.docker.internal:1234/v1
# NEO4J_URI=bolt://neo4j:7687
# EMBEDDING_BASE_URL=http://host.docker.internal:1234
# OPENAI_API_BASE_URL=http://host.docker.internal:1234
